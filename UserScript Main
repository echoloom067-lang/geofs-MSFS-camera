      .mc7-sw input:checked+.mc7-trk{background:rgba(0,180,255,.2);border-color:#00d4ff}
      .mc7-sw input:checked+.mc7-trk .mc7-knob{transform:translateX(13px);background:#00d4ff}
      .mc7-sep{height:1px;background:rgba(0,200,255,.07);margin:2px 0 8px}
