        <div class="mc7-badge on" id="mc7-en">ACTIVE</div>
      </div>
      <div class="mc7-body">

        <div class="mc7-sec">Roll Lag</div>
        <div class="mc7-row"><span class="mc7-lbl">Pull</span><input class="mc7-sl" type="range" id="mc7-rs" min="1" max="25" step="0.5" value="${CFG.roll.stiffness}"><span class="mc7-val" id="mc7-rs-v">${CFG.roll.stiffness}</span></div>
