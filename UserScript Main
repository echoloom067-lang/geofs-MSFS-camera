// ==UserScript==
// @name         GeoFS — MSFS 2020 Cinematic Camera
// @namespace    https://greasyfork.org/
// @version      7.0.0
// @description  MSFS spring camera + ground rumble + touchdown thump + TRUE buttery smooth zoom
// @author       Echoloom
// @match        https://www.geo-fs.com/geofs.php*
// @match        https://*.geo-fs.com/geofs.php*
// @grant        none
// ==/UserScript==

(function () {
  'use strict';

  // ══════════════════════════════════════════════════════════════════════════
  //  HOW SMOOTH ZOOM WORKS HERE (why v6 failed):
  //
  //  GeoFS zoom = it moves the Cesium camera along its own direction vector
  //  (dolly in/out). There is no single "distance" property to write to —
  //  GeoFS recalculates the camera position from scratch every frame.
  //
  //  The fix:
  //  1. Intercept wheel events with capture+preventDefault so GeoFS NEVER
  //     sees them — its snap-zoom code never runs.
  //  2. We accumulate a smooth TARGET distance ourselves.
  //  3. Every frame, after our spring rotation override, we also override
  //     the camera POSITION by computing: aircraftPos + (-direction * dist)
  //     using the Cesium camera's current direction vector and our smoothed dist.
  //  4. Exponential decay eases currentDist → targetDist every frame = silk.
  // ══════════════════════════════════════════════════════════════════════════

  const CFG = {
    enabled: true,

    roll:    { stiffness: 6.0,  damp: 4.8 },
    heading: { stiffness: 9.0,  damp: 5.8 },
    pitch:   { stiffness: 14.0, damp: 7.5 },

    zoom: {
      enabled:    true,
      lambda:     4.0,      // easing speed — 4 = MSFS feel (lower = floatier)
      stepFactor: 0.13,     // how far each scroll tick moves target (fraction of current dist)
      minDist:    10,       // metres
      maxDist:    3000,
    },

    groundShake: {
      enabled:      true,
      maxMagnitude: 0.0055,
      fullSpeedKts: 80,
      frequency:    14.0,
    },

    touchdown: {
      enabled:        true,
      vsThresholdFpm: -150,
      peakMagnitude:  0.018,
      decayRate:      8.0,
      cooldown:       3.0,
    },
  };

  // ── Spring state ──────────────────────────────────────────────────────────
  const spring = {
    roll:    { val: 0, vel: 0 },
    heading: { val: 0, vel: 0 },
    pitch:   { val: 0, vel: 0 },
  };

  const shake = {
    impactAmplitude: 0,
    impactLastTime:  0,
    impactStartTime: 0,
    wasOnGround:     false,
  };

  // Zoom state
  const zst = {
    current: -1,   // current smoothed distance (metres), -1 = uninitialised
    target:  -1,
  };

  let initialized = false;
  let lastT = performance.now();

  // ── Helpers ───────────────────────────────────────────────────────────────
  function springStep(s, target, cfg, dt) {
    let err = target - s.val;
    while (err >  Math.PI) err -= 2 * Math.PI;
    while (err < -Math.PI) err += 2 * Math.PI;
    const acc = cfg.stiffness * err - cfg.damp * s.vel;
    s.vel += acc * dt;
    s.val += s.vel * dt;
  }

  function expDecay(cur, tgt, lambda, dt) {
    return tgt + (cur - tgt) * Math.exp(-lambda * dt);
  }

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function rumbleNoise(t, seed) {
    return (
      Math.sin(t * 1.000 + seed)       * 0.40 +
      Math.sin(t * 1.618 + seed * 1.3) * 0.25 +
      Math.sin(t * 2.414 + seed * 0.7) * 0.20 +
      Math.sin(t * 3.141 + seed * 1.9) * 0.15
    );
  }

  // Measure how far the Cesium camera currently sits from the aircraft
  function measureCurrentDist(cesiumCam) {
    try {
      const ac = window.geofs?.aircraft?.instance;
      // GeoFS puts the aircraft world position in geofs.aircraft.instance.rigidBody?.position
      // or on the object3d. Try both.
      let ap = ac?.rigidBody?.position || ac?.object3d?.position;
      if (!ap) return 80;
      const cp = cesiumCam.positionWC;
      const dx = cp.x - ap.x, dy = cp.y - ap.y, dz = cp.z - ap.z;
      return Math.sqrt(dx*dx + dy*dy + dz*dz);
    } catch (_) { return 80; }
  }

  // ══════════════════════════════════════════════════════════════════════════
  //  WHEEL INTERCEPT — block GeoFS, handle zoom ourselves
  // ══════════════════════════════════════════════════════════════════════════
  function hookScroll() {
    window.addEventListener('wheel', function onWheel(e) {
      if (!CFG.enabled || !CFG.zoom.enabled) return;

      // Stop GeoFS from ever seeing this event
      e.stopImmediatePropagation();
      e.preventDefault();

      // Init target if needed
      if (zst.target < 0) {
        const d = measureCurrentDist(window.geofs?.api?.viewer?.camera);
        zst.current = d;
        zst.target  = d;
      }

      const dir = e.deltaY > 0 ? 1 : -1;          // 1 = zoom out, -1 = zoom in
      zst.target *= (1 + dir * CFG.zoom.stepFactor);
      zst.target  = clamp(zst.target, CFG.zoom.minDist, CFG.zoom.maxDist);

    }, { capture: true, passive: false });
  }

  // ══════════════════════════════════════════════════════════════════════════
  //  MAIN HOOK — runs after geofs.camera.update() every frame
  // ══════════════════════════════════════════════════════════════════════════
  function afterCameraUpdate() {
    if (!CFG.enabled) return;
    try {
      const geofs = window.geofs;
      if (!geofs?.animation?.values || !geofs?.api?.viewer) return;
      const cesiumCam = geofs.api.viewer.camera;
      if (!cesiumCam) return;

      // After GeoFS update, Cesium cam = true aircraft angles + GeoFS-chosen distance
      const trueH   = cesiumCam.heading;
      const trueP   = cesiumCam.pitch;
      const trueR   = cesiumCam.roll;

      if (!isFinite(trueH) || !isFinite(trueP) || !isFinite(trueR)) return;

      // ── Seed on first frame ──────────────────────────────────────────────
      if (!initialized) {
        spring.heading.val = trueH; spring.heading.vel = 0;
        spring.pitch.val   = trueP; spring.pitch.vel   = 0;
        spring.roll.val    = trueR; spring.roll.vel    = 0;
        shake.wasOnGround  = false;
        zst.current        = measureCurrentDist(cesiumCam);
        zst.target         = zst.current;
        initialized        = true;
        return;
      }

      const now = performance.now();
      const dt  = Math.min((now - lastT) / 1000, 0.05);
      lastT = now;
      const t = now / 1000;

      // ── Spring rotation ──────────────────────────────────────────────────
      springStep(spring.heading, trueH, CFG.heading, dt);
      springStep(spring.pitch,   trueP, CFG.pitch,   dt);
      springStep(spring.roll,    trueR, CFG.roll,    dt);

      // ── Smooth zoom ──────────────────────────────────────────────────────
      // Ease current distance toward target
      if (CFG.zoom.enabled && zst.target > 0) {
        zst.current = expDecay(zst.current, zst.target, CFG.zoom.lambda, dt);
      }

      // ── Aircraft / shake data ────────────────────────────────────────────
      const vals     = geofs.animation.values;
      const onGround = !!(vals.groundContact || vals.onGround || (vals.altitude != null && vals.altitude < 5));
      const speedKts = Math.abs(vals.kias || vals.speed || 0);
      const vsFpm    = (vals.verticalSpeed || 0) * 196.85;

      if (CFG.touchdown.enabled) {
        const td = CFG.touchdown;
        if (!shake.wasOnGround && onGround && vsFpm < td.vsThresholdFpm &&
            (t - shake.impactLastTime) > td.cooldown) {
          const hardness = Math.min(Math.abs(vsFpm) / 800, 1.5);
          shake.impactAmplitude = td.peakMagnitude * hardness;
          shake.impactLastTime  = t;
          shake.impactStartTime = t;
          console.log(`%c[MSFS Cam] Touchdown! ${Math.round(vsFpm)} fpm · ${hardness.toFixed(2)}x`,
            hardness > 1 ? 'color:#ff6644' : 'color:#44cc88');
        }
        shake.wasOnGround = onGround;
      }
      if (shake.impactAmplitude > 0.00001)
        shake.impactAmplitude *= Math.exp(-CFG.touchdown.decayRate * dt);
      else shake.impactAmplitude = 0;

      let shakeP = 0, shakeR = 0;
      if (CFG.groundShake.enabled && onGround && speedKts > 2) {
        const gs = CFG.groundShake;
        const spd = Math.min(speedKts / gs.fullSpeedKts, 1);
        const mag = gs.maxMagnitude * spd * Math.min(speedKts / 10, 1);
        const frq = gs.frequency * (spd * 0.7 + 0.3);
        shakeP += rumbleNoise(t * frq, 0) * mag;
        shakeR += rumbleNoise(t * frq * 0.85, 7.3) * mag * 0.7;
      }
      if (shake.impactAmplitude > 0) {
        const ph = (t - shake.impactStartTime) * 18;
        shakeP += Math.sin(ph)       * shake.impactAmplitude;
        shakeR += Math.sin(ph * 0.7) * shake.impactAmplitude * 0.6;
        if (shake.impactAmplitude > 0.005)
          spring.heading.val += Math.sin(ph * 0.4) * shake.impactAmplitude * 0.3 * dt * 6;
      }

      // ── Build final camera orientation ───────────────────────────────────
      const finalH = spring.heading.val;
      const finalP = spring.pitch.val + shakeP;
      const finalR = spring.roll.val  + shakeR;

      // ── Compute smooth-zoom camera position ──────────────────────────────
      // GeoFS already placed the camera at some position. We need the aircraft
      // world-space position, then push the camera back along its look direction
      // by our smoothed distance.
      //
      // Cesium direction vector points FROM camera TOWARD target.
      // So: cameraPos = aircraftPos - direction * dist
      //
      // We use the CURRENT (post-spring) direction rather than Cesium's stored
      // direction so position and orientation stay in sync.

      let finalPos = cesiumCam.positionWC; // fallback = keep GeoFS position

      if (CFG.zoom.enabled && zst.current > 0) {
        try {
          const ac  = geofs.aircraft.instance;
          const ap  = ac?.rigidBody?.position || ac?.object3d?.position;
          if (ap) {
            // Compute look direction from our spring-smoothed HPR
            // In Cesium, heading=0 points North, pitch=0 is horizontal.
            // direction = (cos(pitch)*sin(heading), cos(pitch)*cos(heading), -sin(pitch))
            // but in ECEF we need to rotate by the surface normal at the aircraft's position.
            // Simplest correct approach: use cesiumCam.directionWC (set by setView below after
            // we call it), but we need the position BEFORE setView.
            // So: use the direction that Cesium has right now (from GeoFS's setView this frame).
            const d  = cesiumCam.directionWC;
            const dist = zst.current;
            finalPos = {
              x: ap.x - d.x * dist,
              y: ap.y - d.y * dist,
              z: ap.z - d.z * dist,
            };
          }
        } catch (_) {}
      }

      // ── Write to Cesium — position + orientation together ────────────────
      cesiumCam.setView({
        destination: finalPos,
        orientation: {
          heading: finalH,
          pitch:   finalP,
          roll:    finalR,
        },
      });

    } catch (_) { /* not ready */ }
  }

  // ══════════════════════════════════════════════════════════════════════════
  //  HOOK GEOFS
  // ══════════════════════════════════════════════════════════════════════════
  function hookGeoFS() {
    const geofs = window.geofs;
    if (!geofs?.camera || typeof geofs.camera.update !== 'function') {
      setTimeout(hookGeoFS, 500); return;
    }
    const orig = geofs.camera.update.bind(geofs.camera);
    geofs.camera.update = function (...args) {
      const r = orig(...args);
      afterCameraUpdate();
      return r;
    };
    hookScroll();
    console.log('%c[MSFS Cam v7] ✨ Loaded — spring · rumble · touchdown · butter zoom', 'color:#00d4ff;font-weight:bold;font-size:12px');
    createUI();
  }

  // ══════════════════════════════════════════════════════════════════════════
