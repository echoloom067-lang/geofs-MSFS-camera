          <label class="mc7-sw"><input type="checkbox" id="mc7-ze" checked><div class="mc7-trk"><div class="mc7-knob"></div></div></label>
        </div>
        <div class="mc7-row">
          <span class="mc7-lbl">Glide</span>
          <input class="mc7-sl" type="range" id="mc7-zl" min="0.5" max="14" step="0.1" value="${CFG.zoom.lambda}">
          <span class="mc7-val" id="mc7-zl-v">${CFG.zoom.lambda}</span>
        </div>
        <div class="mc7-row">
          <span class="mc7-lbl">Step</span>
          <input class="mc7-sl" type="range" id="mc7-zs" min="0.03" max="0.40" step="0.01" value="${CFG.zoom.stepFactor}">
          <span class="mc7-val" id="mc7-zs-v">${CFG.zoom.stepFactor}</span>
        </div>

        <div class="mc7-sep"></div>
        <div class="mc7-sec">Ground Rumble 🛞</div>
        <div class="mc7-tog">
          <span class="mc7-lbl" style="min-width:auto">Enable</span>
          <label class="mc7-sw"><input type="checkbox" id="mc7-ge" ${CFG.groundShake.enabled?'checked':''}><div class="mc7-trk"><div class="mc7-knob"></div></div></label>
        </div>
        <div class="mc7-row"><span class="mc7-lbl">Intensity</span><input class="mc7-sl" type="range" id="mc7-gm" min="0.001" max="0.018" step="0.001" value="${CFG.groundShake.maxMagnitude}"><span class="mc7-val" id="mc7-gm-v">${CFG.groundShake.maxMagnitude}</span></div>
        <div class="mc7-row"><span class="mc7-lbl">Frequency</span><input class="mc7-sl" type="range" id="mc7-gf" min="4" max="30" step="1" value="${CFG.groundShake.frequency}"><span class="mc7-val" id="mc7-gf-v">${CFG.groundShake.frequency}</span></div>

        <div class="mc7-sep"></div>
        <div class="mc7-sec">Touchdown Thump 💥</div>
        <div class="mc7-tog">
          <span class="mc7-lbl" style="min-width:auto">Enable</span>
          <label class="mc7-sw"><input type="checkbox" id="mc7-te" ${CFG.touchdown.enabled?'checked':''}><div class="mc7-trk"><div class="mc7-knob"></div></div></label>
        </div>
        <div class="mc7-row"><span class="mc7-lbl">Peak Force</span><input class="mc7-sl" type="range" id="mc7-tm" min="0.004" max="0.045" step="0.001" value="${CFG.touchdown.peakMagnitude}"><span class="mc7-val" id="mc7-tm-v">${CFG.touchdown.peakMagnitude}</span></div>
        <div class="mc7-row"><span class="mc7-lbl">Decay</span><input class="mc7-sl" type="range" id="mc7-td" min="2" max="20" step="0.5" value="${CFG.touchdown.decayRate}"><span class="mc7-val" id="mc7-td-v">${CFG.touchdown.decayRate}</span></div>

      </div>
      <div class="mc7-foot">
        <kbd>Shift+C</kbd> hide &nbsp;·&nbsp; <kbd>Shift+R</kbd> reset
      </div>
    `;
    document.body.appendChild(el);

    document.getElementById('mc7-en').addEventListener('click', () => {
      CFG.enabled = !CFG.enabled; initialized = false;
      const b = document.getElementById('mc7-en');
      b.textContent = CFG.enabled ? 'ACTIVE' : 'OFF';
      b.className = 'mc7-badge ' + (CFG.enabled ? 'on' : 'off');
    });

    document.getElementById('mc7-ze').addEventListener('change', e => { CFG.zoom.enabled        = e.target.checked; zst.current = zst.target = -1; });
    document.getElementById('mc7-ge').addEventListener('change', e => { CFG.groundShake.enabled = e.target.checked; });
    document.getElementById('mc7-te').addEventListener('change', e => { CFG.touchdown.enabled   = e.target.checked; });

    const sl = (id, vid, fn) => document.getElementById(id).addEventListener('input', e => {
      const v = parseFloat(e.target.value); fn(v); document.getElementById(vid).textContent = v;
    });
    sl('mc7-rs','mc7-rs-v', v => CFG.roll.stiffness           = v);
    sl('mc7-rd','mc7-rd-v', v => CFG.roll.damp                = v);
    sl('mc7-hs','mc7-hs-v', v => CFG.heading.stiffness        = v);
    sl('mc7-hd','mc7-hd-v', v => CFG.heading.damp             = v);
    sl('mc7-ps','mc7-ps-v', v => CFG.pitch.stiffness          = v);
    sl('mc7-pd','mc7-pd-v', v => CFG.pitch.damp               = v);
    sl('mc7-zl','mc7-zl-v', v => CFG.zoom.lambda              = v);
    sl('mc7-zs','mc7-zs-v', v => CFG.zoom.stepFactor          = v);
    sl('mc7-gm','mc7-gm-v', v => CFG.groundShake.maxMagnitude = v);
    sl('mc7-gf','mc7-gf-v', v => CFG.groundShake.frequency    = v);
    sl('mc7-tm','mc7-tm-v', v => CFG.touchdown.peakMagnitude  = v);
    sl('mc7-td','mc7-td-v', v => CFG.touchdown.decayRate      = v);

    let vis = true;
    document.addEventListener('keydown', e => {
      if (!e.shiftKey) return;
      if (e.key === 'C') { vis = !vis; el.classList.toggle('hidden', !vis); }
      if (e.key === 'R') { initialized = false; shake.impactAmplitude = 0; zst.current = zst.target = -1; }
    });
  }

  // ══════════════════════════════════════════════════════════════════════════
  //  BOOT
  // ══════════════════════════════════════════════════════════════════════════
  function waitForGeoFS() {
    if (window.geofs?.camera && typeof window.geofs.camera.update === 'function' && window.geofs.api?.viewer)
      hookGeoFS();
    else
      setTimeout(waitForGeoFS, 500);
  }

  if (document.readyState === 'complete') setTimeout(waitForGeoFS, 3000);
  else window.addEventListener('load', () => setTimeout(waitForGeoFS, 3000));

})();
