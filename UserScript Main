        <div class="mc7-sec">Pitch</div>
        <div class="mc7-row"><span class="mc7-lbl">Pull</span><input class="mc7-sl" type="range" id="mc7-ps" min="2" max="40" step="0.5" value="${CFG.pitch.stiffness}"><span class="mc7-val" id="mc7-ps-v">${CFG.pitch.stiffness}</span></div>
        <div class="mc7-row"><span class="mc7-lbl">Damp</span><input class="mc7-sl" type="range" id="mc7-pd" min="1" max="20" step="0.2" value="${CFG.pitch.damp}"><span class="mc7-val" id="mc7-pd-v">${CFG.pitch.damp}</span></div>

