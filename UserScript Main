        <div class="mc7-row"><span class="mc7-lbl">Pull</span><input class="mc7-sl" type="range" id="mc7-hs" min="1" max="30" step="0.5" value="${CFG.heading.stiffness}"><span class="mc7-val" id="mc7-hs-v">${CFG.heading.stiffness}</span></div>
        <div class="mc7-row"><span class="mc7-lbl">Damp</span><input class="mc7-sl" type="range" id="mc7-hd" min="1" max="18" step="0.2" value="${CFG.heading.damp}"><span class="mc7-val" id="mc7-hd-v">${CFG.heading.damp}</span></div>

